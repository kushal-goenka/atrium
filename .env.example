# atrium environment variables
# copy to .env.local for dev, or mount as secrets in prod

# --- core ---
NODE_ENV=development
ATRIUM_PUBLIC_URL=http://localhost:3000

# --- database ---
# dev default: sqlite. prod: postgres
# postgres example: postgresql://atrium:atrium@localhost:5432/atrium?schema=public
DATABASE_URL="file:./prisma/dev.db"

# --- auth ---
# a random 32+ char string used for session signing
AUTH_SECRET=change-me-in-production-use-openssl-rand-base64-32

# optional: bootstrap admins on first run. comma-separated.
ATRIUM_ADMIN_EMAILS=

# --- oidc (optional) ---
AUTH_OIDC_ISSUER=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=

# --- catalog visibility ---
# if false, the public browse UI requires auth
ATRIUM_PUBLIC_CATALOG=true

# --- security ---
# require a second admin approval for destructive actions
ATRIUM_FOUR_EYES=false

# poll OSV.dev for CVEs against plugin dependencies
ATRIUM_CVE_POLL=false

# --- telemetry ---
# OTLP endpoint for outbound traces. leave empty to disable
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=atrium

# if "off", no telemetry emitted at all
ATRIUM_TELEMETRY=on

# --- ingest ---
# how often to re-sync federated sources, in seconds
ATRIUM_INGEST_INTERVAL=3600

# --- email (for notifications + magic links) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=atrium@yourcompany.com

# --- auth mode ---
# "open" (default): no login, browse + admin open to everyone
# "admin-password": ATRIUM_ADMIN_PASSWORD gates /admin/*; browse stays open
# "sso" (planned for v0.2): OIDC/SAML per-user identity
ATRIUM_AUTH_MODE=open
ATRIUM_ADMIN_PASSWORD=

# --- air-gap posture ---
# "open"      (default) outbound fetches allowed
# "allowlist"           only hosts in ATRIUM_ALLOWED_HOSTS are reachable
# "strict"              block all outbound fetches; ingest must use pre-registered local sources
ATRIUM_AIRGAP=open
ATRIUM_ALLOWED_HOSTS=
