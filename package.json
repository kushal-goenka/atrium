{
  "name": "atrium",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "The open plugin registry for AI agents. Self-host your own. Federate from others. Audit everything.",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.1.0",
    "clsx": "2.1.1",
    "next": "15.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "2.5.5"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "4.1.4",
    "eslint": "9.17.0",
    "eslint-config-next": "15.1.0",
    "happy-dom": "20.9.0",
    "postcss": "8.4.49",
    "prisma": "6.1.0",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "5.7.2",
    "vitest": "4.1.4"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
