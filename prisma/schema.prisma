// atrium database schema
// Portable between SQLite (dev) and Postgres (prod). Enum-ish fields are stored
// as String to keep the schema cross-provider; values are enforced in TS.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// ---------- identity ----------

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String?
  avatarUrl      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lastSeenAt     DateTime?

  roles          UserRole[]
  installs       Install[]
  auditEvents    AuditLog[]    @relation("actor")
  apiTokens      ApiToken[]
}

model Role {
  id          String     @id @default(cuid())
  // Built-in: viewer, installer, curator, admin. Custom roles allowed.
  key         String     @unique
  name        String
  description String?
  builtIn     Boolean    @default(false)

  users       UserRole[]
  policies    Policy[]
}

model UserRole {
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantedAt DateTime @default(now())

  @@id([userId, roleId])
}

model ApiToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  name        String
  scopes      String
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
}

/// ---------- catalog ----------

/// Source.kind: "GIT" | "HTTP" | "LOCAL"
/// Source.trust: "OFFICIAL" | "VERIFIED" | "COMMUNITY" | "INTERNAL"
model Source {
  id             String      @id @default(cuid())
  key            String      @unique
  name           String
  kind           String
  url            String?
  trust          String      @default("community")
  minSyncSec     Int         @default(3600)
  autoQuarantine Boolean     @default(true)
  enabled        Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  snapshots      MarketplaceSnapshot[]
  plugins        Plugin[]
}

model MarketplaceSnapshot {
  id          String   @id @default(cuid())
  sourceId    String
  source      Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  fetchedAt   DateTime @default(now())
  contentHash String
  manifest    String
  error       String?

  @@unique([sourceId, contentHash])
  @@index([sourceId, fetchedAt])
}

/// Plugin.policyState: "APPROVED" | "QUARANTINED" | "BLOCKED" | "DEPRECATED"
model Plugin {
  id           String           @id @default(cuid())
  sourceId     String
  source       Source           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  slug         String
  name         String
  category     String
  description  String
  authorName   String?
  authorEmail  String?
  homepage     String?
  license      String?
  keywords     String
  policyState  String           @default("quarantined")
  updatedAt    DateTime         @updatedAt
  createdAt    DateTime         @default(now())

  versions     PluginVersion[]
  installs     Install[]
  signals      SecuritySignal[]
  usage        UsageDaily[]

  @@unique([sourceId, slug])
  @@index([policyState])
}

model PluginVersion {
  id          String   @id @default(cuid())
  pluginId    String
  plugin      Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  version     String
  releasedAt  DateTime @default(now())
  changelog   String?
  manifest    String
  artifactRef String?

  @@unique([pluginId, version])
  @@index([pluginId, releasedAt])
}

/// ---------- security ----------

/// SecuritySignal.severity: "INFO" | "LOW" | "MEDIUM" | "HIGH"
model SecuritySignal {
  id         String    @id @default(cuid())
  pluginId   String
  plugin     Plugin    @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  scanner    String
  severity   String
  title      String
  detail     String
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  resolvedBy String?

  @@index([pluginId, severity])
}

/// ---------- policy ----------

/// Policy.effect: "ALLOW" | "DENY" | "QUARANTINE"
model Policy {
  id          String   @id @default(cuid())
  name        String
  description String?
  roleId      String?
  role        Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  matcher     String
  effect      String
  priority    Int      @default(100)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// ---------- audit + usage ----------

model Install {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  pluginId   String
  plugin     Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  version    String
  clientType String?
  clientIp   String?
  issuedAt   DateTime @default(now())

  @@index([pluginId, issuedAt])
  @@index([userId, issuedAt])
}

model UsageDaily {
  id          String   @id @default(cuid())
  pluginId    String
  plugin      Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  day         DateTime
  installs    Int      @default(0)
  commands    Int      @default(0)
  activeUsers Int      @default(0)

  @@unique([pluginId, day])
}

/// AuditLog.action: see AUDIT_ACTIONS in lib/types.ts
model AuditLog {
  id         String   @id @default(cuid())
  at         DateTime @default(now())
  actorId    String?
  actor      User?    @relation("actor", fields: [actorId], references: [id], onDelete: SetNull)
  actorKind  String?
  action     String
  targetKind String
  targetId   String?
  detail     String
  meta       String?

  @@index([at])
  @@index([targetKind, targetId])
}

/// ---------- provider keys / LLM routing ----------

/// ProviderConfig stores API keys and base URLs for external LLM providers.
/// Used by the AI curation engine and any other feature that needs an LLM.
/// `apiKeyCipher` is AES-256-GCM encrypted; plaintext is never persisted.
model ProviderConfig {
  id            String    @id @default(cuid())
  /// "anthropic" | "openai" | "gemini" | "azure-openai" | "litellm-proxy" | "custom"
  provider      String    @unique
  displayName   String
  /// AES-GCM ciphertext of the API key. See lib/crypto.ts format.
  apiKeyCipher  String
  /// Last 4 chars of the plaintext key, shown in UI. Not sensitive.
  apiKeyTail    String
  /// Optional base URL override (Azure OpenAI, LiteLLM proxy, custom).
  baseUrl       String?
  /// Default model id to use for this provider's requests.
  defaultModel  String?
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastUsedAt    DateTime?
}

/// ---------- plugin overrides (pin / fork / curation) ----------

/// Per-plugin admin overrides. Applied when serving /mkt/marketplace.json.
model PluginOverride {
  id              String   @id @default(cuid())
  /// Composite of sourceKey:pluginSlug so it's unique across sources.
  pluginKey       String   @unique
  /// If set, serve only this version regardless of what the source reports.
  pinnedVersion   String?
  /// Category override (replaces whatever the source reported).
  categoryOverride String?
  /// JSON-encoded string array for keyword/tag override.
  keywordsOverride String?
  /// Hidden from serving + browse until cleared.
  hidden          Boolean  @default(false)
  /// Free-form note for the audit trail.
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
}

/// A local fork of an external plugin. The fork lives under an internal
/// source key; forked plugins can diverge from the upstream independently.
model PluginFork {
  id               String   @id @default(cuid())
  /// slug:sourceKey pair that is the new fork (internal).
  forkSlug         String
  forkSourceKey    String
  /// The upstream we were forked from.
  upstreamSlug     String
  upstreamSourceKey String
  /// Version at the time of fork.
  forkedAtVersion  String
  /// JSON-encoded manifest captured at fork time, in case upstream disappears.
  snapshotManifest String
  notes            String?
  createdAt        DateTime @default(now())
  createdBy        String?

  @@unique([forkSourceKey, forkSlug])
}

/// AI-generated curation suggestions. Lives alongside the plugin; admin
/// can accept / edit / reject. Accepted suggestions become PluginOverride rows.
model CurationSuggestion {
  id          String    @id @default(cuid())
  pluginKey   String
  /// "category" | "keywords"
  field       String
  suggested   String
  /// "anthropic" | "openai" | "gemini" — whichever provider we called.
  generatedBy String
  /// Confidence 0..1 if the model returned one; else null.
  confidence  Float?
  status      String    @default("pending") // "pending" | "accepted" | "rejected" | "edited"
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  @@index([pluginKey, status])
}

/// ---------- community feedback ----------

/// User-submitted suggestion / plugin request. Surfaces in /suggestions,
/// and admins can triage (close, mark shipped, convert to an internal
/// plugin request). Vote count is denormalized for ordering; the canonical
/// truth lives in SuggestionVote.
model Suggestion {
  id            String   @id @default(cuid())
  title         String
  body          String
  /// "plugin-request" | "feature" | "bug" | "general"
  kind          String   @default("plugin-request")
  /// "claude-code" | "openai" | "gemini" | "mcp" | "generic" | null
  provider      String?
  /// "open" | "under-review" | "in-progress" | "shipped" | "closed"
  status        String   @default("open")
  createdBy     String
  createdByName String?
  votes         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
  @@index([votes])
}

model SuggestionVote {
  id           String   @id @default(cuid())
  suggestionId String
  /// Mock-user email in the alpha; Prisma User.id once SSO lands.
  userId       String
  at           DateTime @default(now())

  @@unique([suggestionId, userId])
}

/// ---------- user-contributed skills ----------

/// A skill uploaded by an end user (not an admin federating from an
/// external source). Lands in quarantine by default; curator promotes it
/// into the "user-contributions" internal source's surface.
model UploadedSkill {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  /// Markdown body of the skill (SKILL.md contents).
  body        String
  /// Freeform csv of user-supplied tags; the AI curator can suggest more.
  keywords    String
  category    String   @default("other")
  uploadedBy  String
  uploaderName String?
  version     String   @default("0.1.0")
  /// "quarantined" | "approved" | "rejected"
  policyState String   @default("quarantined")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([uploadedBy])
  @@index([policyState])
}
